@startuml TheBunny_Sequence_PostComment

!theme cerulean-outline

' ===== Layout =====
skinparam shadowing false
skinparam roundCorner 10
skinparam padding 4
skinparam ParticipantPadding 24
skinparam BoxPadding 14
skinparam sequenceMessageAlign center

' ===== Typography =====
skinparam DefaultFontName "Inter, Segoe UI, Helvetica Neue, sans-serif"
skinparam DefaultFontSize 12
skinparam TitleFontSize 18
skinparam TitleFontStyle bold
skinparam TitleFontColor #0f172a

' ===== Actors =====
skinparam ActorStyle awesome
skinparam ActorBorderColor #1e293b
skinparam ActorBackgroundColor #ffffff
skinparam ActorFontStyle bold

' ===== Participants =====
skinparam ParticipantBorderColor #475569
skinparam ParticipantBorderThickness 1.2
skinparam ParticipantBackgroundColor #ffffff
skinparam ParticipantFontStyle bold
skinparam ParticipantFontColor #0f172a

' ===== Database =====
skinparam DatabaseBackgroundColor #fee2e2
skinparam DatabaseBorderColor #b91c1c

' ===== Lifeline / Activation =====
skinparam SequenceLifeLineBorderColor #cbd5e1
skinparam SequenceLifeLineBackgroundColor #f1f5f9
skinparam SequenceGroupBodyBackgroundColor #f8fafc
skinparam SequenceGroupBorderColor #94a3b8
skinparam SequenceGroupFontStyle bold
skinparam SequenceGroupFontColor #1e293b
skinparam SequenceDividerBackgroundColor #e2e8f0
skinparam SequenceDividerBorderColor #94a3b8
skinparam SequenceDividerFontStyle bold

' ===== Arrows =====
skinparam SequenceArrowColor #475569
skinparam SequenceArrowThickness 1.2
skinparam SequenceArrowFontColor #334155
skinparam SequenceArrowFontSize 11

' ===== Note =====
skinparam NoteBackgroundColor #fffbeb
skinparam NoteBorderColor #fcd34d
skinparam NoteFontColor #78350f
skinparam NoteFontSize 10

title Sequence Diagram (1/3) — Đăng bài & Bình luận

actor "Người dùng A"     as A  #E0E7FF
actor "Người dùng B"     as B  #DCFCE7
box "Frontend" #F8FAFC
  participant "WebApp" as Web
end box
box "Application Layer" #DCFCE7
  participant "PostController"     as PC
  participant "BaiDang\n<<Entity>>" as BD
  participant "BinhLuan\n<<Entity>>" as BL
  participant "ThongBao\n<<Service>>" as TB
end box
database "MariaDB" as DB

== Đăng bài ==
A -> Web : Nhập nội dung & submit
activate Web
Web -> PC : POST /posts {noi_dung}
activate PC
PC -> BD : new BaiDang(userId, noiDung)
activate BD
BD -> DB : INSERT INTO bai_dang
DB --> BD : id, createdAt
BD --> PC : BaiDang
deactivate BD
PC --> Web : 201 Created
deactivate PC
Web --> A : Hiển thị bài đăng
deactivate Web

== Bình luận ==
B -> Web : Mở feed, chọn bài đăng
activate Web
Web -> PC : GET /posts/:id
activate PC
PC -> DB : SELECT bài đăng + comments
DB --> PC : data
PC --> Web : Render
deactivate PC
Web --> B : Hiển thị bài đăng
deactivate Web

B -> Web : Viết bình luận
activate Web
Web -> PC : POST /posts/:id/comments
activate PC
PC -> BL : new BinhLuan(baiDangId, userId, noiDung)
activate BL
BL -> DB : INSERT INTO binh_luan
DB --> BL : id
BL --> PC : BinhLuan
deactivate BL

PC -> TB : notifyPostOwner(baiDang.userId)
activate TB
TB -> DB : INSERT INTO thong_bao
TB --> A : Push notification (realtime)
deactivate TB
PC --> Web : 201 Created
deactivate PC
Web --> B : Hiển thị bình luận
deactivate Web

note over PC, TB #fffbeb
  **Observer pattern** — PostController phát event,
  ThongBaoService lắng nghe & gửi push notification.
end note

@enduml

