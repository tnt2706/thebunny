title Sequence Diagram (3/3) — Báo cáo vi phạm & xử lý

actor "Người dùng"    as U   #DCFCE7
actor "Quản trị viên" as QTV #FEF9C3
box "Moderation Domain" #F1F5F9
  participant "ModerationController" as MC
  participant "BaoCaoViPham"         as BCVP
  participant "User\n<<Entity>>"     as USR
  participant "ThongBao"             as TB
end box
database "MariaDB" as DB

== Người dùng gửi báo cáo ==
U -> MC : POST /reports\n{bai_dang_id, ly_do}
activate MC
MC -> BCVP : new BaoCaoViPham(reporterId, baiDangId, lyDo)
activate BCVP
BCVP -> DB : INSERT trang_thai='Pending'
BCVP --> MC : reportId
deactivate BCVP
MC --> U : 201 — đã ghi nhận

MC -> TB : notifyAdmins("Có báo cáo mới")
activate TB
TB -> DB : INSERT INTO thong_bao (admins)
TB --> QTV : Push notification
deactivate TB
deactivate MC

== QTV duyệt báo cáo ==
QTV -> MC : GET /reports?status=Pending
activate MC
MC -> DB : SELECT báo cáo
MC --> QTV : danh sách
deactivate MC

QTV -> MC : POST /reports/:id/review {action}
activate MC

alt #DCFCE7 action == 'resolve' (xác nhận vi phạm)
  MC -> BCVP : resolve()
  activate BCVP
  BCVP -> DB : UPDATE trang_thai='Resolved'
  deactivate BCVP
  MC -> USR : ban(nguoiBiBaoCaoId)
  activate USR
  USR -> DB : UPDATE status='Banned'
  deactivate USR
  MC -> TB : notify("Tài khoản bị khóa")
else #FEE2E2 action == 'reject'
  MC -> BCVP : reject()
  activate BCVP
  BCVP -> DB : UPDATE trang_thai='Rejected'
  deactivate BCVP
  MC -> TB : notify("Báo cáo bị từ chối")
end

MC --> QTV : Xong
deactivate MC

note over MC, USR #fffbeb
  Khi **resolve**, hệ thống đồng thời:
  cập nhật trạng thái báo cáo → ban user → gửi thông báo.
end note

@enduml
