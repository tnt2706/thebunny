title Sequence Diagram (2/3) — Thách đấu PvP end-to-end

actor "Người chơi 1" as P1 #E0E7FF
actor "Người chơi 2" as P2 #FCE7F3
box "Competition Domain" #FFF7ED
  participant "MatchService"   as MS
  participant "PhongThachDau"  as PTD
  participant "TranDau"        as TD
  participant "CauHoi"         as CH
  participant "HangThoService" as HTS
end box
database "MariaDB" as DB

== Tạo phòng & tham gia ==
P1 -> MS : createRoom(boDeId)
activate MS
MS -> PTD : new PhongThachDau(boDeId)
activate PTD
PTD -> DB : INSERT INTO phong_thach_dau
PTD --> MS : phongId
deactivate PTD
MS --> P1 : phongId
deactivate MS

P2 -> MS : joinRoom(phongId)
activate MS
MS -> DB : INSERT user_phong_thach_dau (P1, P2)
MS --> P2 : joined
deactivate MS

== Khởi tạo trận đấu ==
MS -> TD : new TranDau(phongId, P1, P2)
activate TD
TD -> DB : INSERT trang_thai='cho'
MS -> TD : start()
TD -> DB : UPDATE trang_thai='dang_dau'\n          started_at=NOW()

== Vòng câu hỏi ==
loop Mỗi câu hỏi trong bộ đề
  MS -> CH : nextQuestion(boDeId)
  activate CH
  CH -> DB : SELECT * FROM cau_hoi
  CH --> MS : question
  deactivate CH
  par Gửi đồng thời
    MS -> P1 : show question
  also
    MS -> P2 : show question
  end
  P1 --> MS : answer
  P2 --> MS : answer
  MS -> TD : updateScore(P1, P2)
end

== Kết thúc ==
MS -> TD : end()
TD -> DB : UPDATE trang_thai='ket_thuc'\n          ended_at=NOW()
deactivate TD
MS -> HTS : updateRank(winner, loser)
activate HTS
HTS -> DB : UPDATE user_hang_tho
par
  HTS --> P1 : Cập nhật hạng mới
also
  HTS --> P2 : Cập nhật hạng mới
end
deactivate HTS

note over MS, HTS #fffbeb
  Kết thúc trận đấu kéo theo cập nhật bảng xếp hạng
  (HangTho) cho **cả hai** người chơi.
end note

@enduml

