' ============================================================
' TheBunny — State Diagrams (Nhóm 10)
' Style đồng bộ với class & sequence diagram
' ============================================================

@startuml TheBunny_State_TranDau

!theme cerulean-outline

' ===== Layout =====
skinparam shadowing false
skinparam roundCorner 14
skinparam padding 5
skinparam nodesep 45
skinparam ranksep 55

' ===== Typography =====
skinparam DefaultFontName "Inter, Segoe UI, Helvetica Neue, sans-serif"
skinparam DefaultFontSize 12
skinparam TitleFontSize 18
skinparam TitleFontStyle bold
skinparam TitleFontColor #0f172a

' ===== State =====
skinparam state {
  BackgroundColor       #ffffff
  BorderColor           #475569
  BorderThickness       1.4
  FontStyle             bold
  FontColor             #0f172a
  AttributeFontSize     11
  AttributeFontColor    #475569
  StartColor            #1e293b
  EndColor              #1e293b
}

' ===== Arrows =====
skinparam ArrowColor #64748b
skinparam ArrowThickness 1.3
skinparam ArrowFontColor #334155
skinparam ArrowFontSize 11
skinparam ArrowFontStyle italic

' ===== Note =====
skinparam NoteBackgroundColor #fffbeb
skinparam NoteBorderColor #fcd34d
skinparam NoteFontColor #78350f
skinparam NoteFontSize 10

title State Diagram (1/3) — TranDau (Trận đấu PvP)

state "cho"      as cho      #E0E7FF
state "dang_dau" as dang_dau #DCFCE7
state "ket_thuc" as ket_thuc #FEF9C3

[*]      --> cho      : khởi tạo trận

cho      : entry / started_at = null
cho      : entry / ended_at   = null
cho      --> dang_dau : start()\n[cả 2 người chơi sẵn sàng]

dang_dau : entry / started_at = NOW()
dang_dau : do    / cập nhật điểm theo câu trả lời
dang_dau --> ket_thuc : end()\n[hết câu hỏi hoặc 1 bên thoát]

ket_thuc : entry / ended_at = NOW()
ket_thuc : entry / cập nhật user_hang_tho
ket_thuc --> [*]

note right of cho
  **Trạng thái chờ**
  Phòng đã có 2 người
  nhưng chưa bấm "Bắt đầu"
end note

note right of dang_dau
  Cả hai người chơi
  trả lời câu hỏi **song song**
end note

@enduml

